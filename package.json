{
  "name": "frontend-eventyr-template-react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "prebuild": "shx cp ./config/vercel.json vercel.json",
    "build": "tsc && vite build",
    "predeploy": "shx cp ./config/vercel.json vercel.json",
    "deploy": "vercel",
    "dev": "vite",
    "dev:noauth": "cross-env VITE_NO_AUTH=1 vite",
    "prevercel:dev": "shx rm -f vercel.json",
    "vercel:dev": "vercel dev",
    "vercel:login": "vercel login"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.36.0",
    "axios": "^1.6.8",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "vercel": "^34.1.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.1.2",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "shx": "^0.3.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
